# Required: Honeycomb ingest API key (env-scoped)
HONEYCOMB_API_KEY=                                                 

# Required: where the gateway is reachable                         
GATEWAY_URL=http://localhost:3000                                

# Optional: requests per second (default: 1)                       
# REQUESTS_PER_SECOND=1
                                                                  
# Optional: OTel overrides (defaults work for Honeycomb)           
# OTEL_SERVICE_NAME=loadgen
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://api.honeycomb.io/v1/traces     