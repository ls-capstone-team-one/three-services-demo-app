{
  "name": "three-services-demo-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "dev": "concurrently -n gateway,orders,inventory -c blue,yellow,green \"npm:dev:gateway\" \"npm:dev:orders\" \"npm:dev:inventory\"",
    "dev:gateway": "npm --workspace gateway run dev",
    "dev:orders": "npm --workspace orders run dev",
    "dev:inventory": "npm --workspace inventory run dev",
    "dev:loadgen": "npm --workspace loadgen run dev",
    "build": "npm run build --workspaces",
    "test": "npm test --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
